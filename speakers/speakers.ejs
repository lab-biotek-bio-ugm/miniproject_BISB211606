```{=html}
<div class='sponsorsFooter'>
      <h1 id="sponsorTitle" data-default-title="<strong>Speakers</strong>"><strong>Guest Lectures</strong></h1>
      <ul>
        <% for (const item of items) { %>
							<li><a href="<%- item.href %>" target="_blank" class=""><img width="200" height="200" style="border-radius: 40%;" class="" src="<%- item.thumbnail %>" alt="<%= item.name %> picture" /></a>
							
              <p><strong> <%= item.name %> </strong> <br/>
              <%= item.affiliation %> <br/>
              </p>
              <ul style="margin-top:0;margin-bottom:0.035rem;padding-left:0;display:inline-block;">
                  <li class="socialIcons" style="list-style:none;margin:0;padding:0;display:inline-flex;align-items:center;gap:8px;">
                    <% if (item.country) { %>
                      <img src="https://flagcdn.com/24x18/<%= item.country.toLowerCase() %>.png" alt="flag" style="width:20px;height:auto;vertical-align:middle;"/>
                    <% } %>
                    <% for (const tile of item.social) { %>
                      <% if (tile.website) { %>
                        <a class="" href="<%- tile.website %>">
                          <i class="bi bi-globe"></i>
                        </a>
                      <% } %>
                      <% if (tile.github) { %>
                        <a class="" href="<%- tile.github %>">
                          <i class="bi bi-github"></i>
                        </a>
                      <% } %>
                      <% if (tile.twitter) { %>
                        <a class="" href="<%- tile.twitter %>">
                          <i class="bi bi-twitter"></i>
                        </a>
                      <% } %>
                      <% if (tile.linkedin) { %>
                        <a class="" href="<%- tile.linkedin %>">
                          <i class="bi bi-linkedin"></i>
                        </a>
                      <% } %>
                      <% if (tile.facebook) { %>
                        <a class="" href="<%- tile.facebook %>">
                          <i class="bi bi-facebook"></i>
                        </a>
                      <% } %>
                      <% if (tile.mastodon) { %>
                        <a class="" href="<%- tile.mastodon %>">
                          <i class="bi bi-mastodon"></i>
                        </a>
                      <% } %>
                    <% } %>
                  </li>
                </ul>
							</li>
        <% } %>
      </ul>
    </div>
</div>
```